# ============================================================
# GitHub MCP Server
# ============================================================
# Classic PAT at: https://github.com/settings/tokens
# Scopes: repo, read:org, issues, pull_requests
GITHUB_TOKEN=ghp_your_classic_pat_here
GITHUB_ORG=your-org-name

# ============================================================
# Atlassian MCP Server (Confluence + Jira)
# ============================================================
# Legacy API tokens at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_API_TOKEN=your_confluence_legacy_token
CONFLUENCE_USERNAME=your-email@example.com
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_API_TOKEN=your_jira_legacy_token
JIRA_USERNAME=your-email@example.com

# ============================================================
# Google MCP Server (Drive + Gmail + Calendar)
# ============================================================
# Set up at: https://console.cloud.google.com/
# 1. Create a project, enable Drive/Gmail/Calendar APIs
# 2. Create a service account with JSON key, or OAuth2 client ID
# 3. For service accounts, optionally set GOOGLE_SERVICE_ACCOUNT and GOOGLE_DOMAIN
# 4. Point GOOGLE_CREDENTIALS to the JSON file
GOOGLE_CREDENTIALS=/path/to/credentials.json
# GOOGLE_SERVICE_ACCOUNT=sa@project.iam.gserviceaccount.com
# GOOGLE_DOMAIN=yourcompany.com
